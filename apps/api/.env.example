# ─────────────────────────────────────────────────────────────────────────────
# CORA API — environment template. Copy to `.env` and fill in.
# In production, set these as platform secrets (e.g. `fly secrets set ...`),
# NOT in a committed file. Never commit a real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# Public base URL of THIS API. Used to build Blink challenge links.
# Production example: https://cora-api.fly.dev
API_BASE_URL=http://localhost:8080

# Frontend origin(s) allowed by CORS (comma-separated for more than one).
# Leave unset for permissive local/devnet dev; set in production to lock CORS.
# Example: https://cora.vercel.app
# FE_BASE_URL=

# ── Server settlement keypair ────────────────────────────────────────────────
# Signs settlement transactions; its pubkey is embedded in on-chain MatchState.
# Format: JSON array of bytes (solana-keygen) OR a base58 string (Phantom export).
#
#   ⚠️  Do NOT set this to `[]` — an empty array crashes with "invalid key size".
#   • Local dev: LEAVE UNSET → an ephemeral throwaway keypair is generated.
#   • Production: set ONE persistent, funded keypair. Changing it between restarts
#     makes in-flight matches unsettleable (signature/pubkey mismatch).
# SERVER_KEYPAIR=

# Treasury authority pubkey — token accounts owned by this key receive the 2.5%
# fee. Falls back to the server keypair's pubkey if unset (dev convenience only).
# TREASURY_PUBKEY=

# ── Solana RPC ───────────────────────────────────────────────────────────────
# RPCFast recommended (https://solana.rpcfast.com) — public RPC is rate-limited.
# Fallback: https://api.devnet.solana.com
SOLANA_RPC_URL=https://solana.rpcfast.com/YOUR_API_KEY
# WSS endpoint for on-chain event streaming. Derived from SOLANA_RPC_URL if unset.
# SOLANA_WS_URL=wss://solana.rpcfast.com/YOUR_API_KEY

# ── GoldRush / Covalent (token pricing & balances) ───────────────────────────
# Required for live pricing/balance checks. If unset, those features are disabled
# (the server still boots and falls back gracefully).
GOLDRUSH_API_KEY=cqt_YOUR_API_KEY

# ── Supabase (persistence) ───────────────────────────────────────────────────
# If unset, the API falls back to IN-MEMORY stores — match/queue/blink/history
# data is lost on every restart. Set all three for production.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ── On-chain program IDs (override the in-code devnet fallbacks) ──────────────
# CORA_ESCROW_PROGRAM_ID=8h5gHVN29FzmeJSbQXtrvEptxUmDKFag9BQCy3Ky1ZxN
# CORA_BATTLE_PROGRAM_ID=Azn65FT27X2VpXHgLCXPCqjgWKEeveVzGqEvZcNp2Lic

# ── MagicBlock Ephemeral Rollup (optional — only for delegated battle state) ──
# MAGICBLOCK_ROUTER_RPC_URL=https://devnet-router.magicblock.app
# MAGICBLOCK_ROUTER_WS_URL=wss://devnet-router.magicblock.app
# MAGICBLOCK_RPC_URL=
# MAGICBLOCK_WS_URL=
# MAGICBLOCK_VALIDATOR_IDENTITY=
# MAGICBLOCK_LOCAL_VALIDATOR_IDENTITY=
# EPHEMERAL_PROVIDER_ENDPOINT=
# EPHEMERAL_WS_ENDPOINT=

# ── Battle tuning (optional — sane defaults in code) ─────────────────────────
# CORA_BATTLE_PRE_REGISTER_CARD_LIMIT=128
# CORA_BATTLE_MAX_EFFECT_VALUE=
# CORA_BATTLE_SETUP_FEE_CUSHION_LAMPORTS=
