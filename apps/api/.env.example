# ─────────────────────────────────────────────────────────────────────────────
# CORA API — environment template. Copy to `.env` and fill in.
# In production, set these as platform secrets (e.g. `fly secrets set ...`),
# NOT in a committed file. Never commit a real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# Public base URL of THIS API.
# Production example: https://cora-game-api.fly.dev
API_BASE_URL=http://localhost:8080

# Frontend origin(s) allowed by CORS (comma-separated for more than one).
# Leave unset for permissive local dev; set in production to lock CORS.
# Also used to build the /challenge/<roomId> invite URL.
# Example: https://coragames.fun
# FE_BASE_URL=

# ── Server settlement signer (EVM EOA) ───────────────────────────────────────
# secp256k1 private key for the server signer. This EOA both signs the EIP-712
# settlement authorization AND submits settleMatch/refund/initializeMatch txs.
# It MUST equal the CoraEscrow contract's `serverSigner`, and must hold Base
# Sepolia ETH to pay gas.
#   • Local dev: leave UNSET → on-chain settlement is skipped (gameplay still works).
#   • Production: set ONE persistent, funded key. 0x-prefixed (or bare hex).
# SERVER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Treasury address — receives the 2.5% fee. Set in the contract at deploy time;
# this var is informational for the API.
# TREASURY_ADDRESS=0xYOUR_TREASURY

# ── Base Sepolia ──────────────────────────────────────────────────────────────
# Paid RPC recommended (Alchemy/Infura) — public endpoint is rate-limited.
# Public fallback: https://sepolia.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# WebSocket endpoint for the event listener. If unset, the listener polls over HTTP.
# BASE_SEPOLIA_WS_URL=wss://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Deployed CoraEscrow contract address (from `forge script Deploy`).
# When unset, settlement/refund/event-listener are disabled (local dev).
# ESCROW_CONTRACT_ADDRESS=0xYOUR_ESCROW

# Default per-player wager for queue matches. ETH in wei (default 0.001 ETH);
# USDC in 6-decimal base units (default 1 USDC = 1000000).
# DEFAULT_WAGER_WEI=1000000000000000
# DEFAULT_WAGER_USDC=1000000

# Wager tokens: native ETH + USDC. USDC defaults to Circle's Base Sepolia USDC
# (0x036CbD53842c5426634e7929541eC2318f3dCF7e); override only if needed.
# USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ── Supabase (persistence) ───────────────────────────────────────────────────
# If unset, the API falls back to IN-MEMORY stores — match/queue/challenge/history
# data is lost on every restart. Set all three for production.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
