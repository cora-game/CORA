# API Environment Variables
PORT=8080

# Base URL for generating Blink URLs (used in POST /match/private response)
API_BASE_URL=http://localhost:8080

# Solana RPC URL — RPCFast recommended (https://rpcfast.com)
# Sign up at https://solana.rpcfast.com → create an app → copy your HTTPS endpoint.
# Free tier available; Frontier Hackathon teams get $10K in credits.
# Fallback: https://api.devnet.solana.com (public, rate-limited)
SOLANA_RPC_URL=https://solana.rpcfast.com/YOUR_API_KEY

# Solana WebSocket URL — RPCFast WSS endpoint for on-chain event streaming.
# Copy from your RPCFast dashboard (Websocket field). If omitted, derived from SOLANA_RPC_URL.
# SOLANA_WS_URL=wss://solana.rpcfast.com/YOUR_API_KEY

# MagicBlock Router RPC — used only for delegated battle-state transactions.
# Keep SOLANA_RPC_URL/RPCFast for escrow settlement and base-layer reads.
# MAGICBLOCK_ROUTER_RPC_URL=https://devnet-router.magicblock.app
# MAGICBLOCK_ROUTER_WS_URL=wss://devnet-router.magicblock.app
# CORA_BATTLE_PROGRAM_ID=3eMDYJTc5uxA5CueLoRvdCiCvhUnjSZS7gVwX6jREQR8
# CORA_ESCROW_PROGRAM_ID=9Pqkgy5uu9w2HvgyNUnHEvzdRWSv1h6GyCuD4uKBVp1W
# CORA_BATTLE_PRE_REGISTER_CARD_LIMIT=128

# Server keypair for signing settlement transactions (DO NOT COMMIT THE REAL .env)
# Format: JSON array of bytes or Base58 encoded string
SERVER_KEYPAIR=[]

# Treasury authority public key — token accounts owned by this key receive the 2.5% fee.
# If not set, falls back to the server keypair's public key (dev convenience only).
# TREASURY_PUBKEY=
