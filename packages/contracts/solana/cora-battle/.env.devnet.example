# Copy this file to `.env.devnet` and fill with your real endpoints.

# Base Solana RPC for Anchor tests and base-layer transactions (escrow/session creation/etc).
# Recommended: your dedicated devnet RPC endpoint (Dynix/Helius/QuickNode/etc).
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com

# Wallet used by ts-mocha / Anchor provider.
ANCHOR_WALLET=/Users/your-user/.config/solana/id.json

# Magic Router / ER endpoints for MagicBlock tests (tests/3*-magicblock-*.test.ts).
EPHEMERAL_PROVIDER_ENDPOINT=https://devnet-router.magicblock.app
EPHEMERAL_WS_ENDPOINT=wss://devnet-router.magicblock.app

# Keep enabled for magicrouter suite.
ENABLE_MAGICBLOCK_LOCAL_STACK_TESTS=1

# Optional for realtime timeout tests (slow on devnet).
ENABLE_REALTIME_TIMEOUT_TESTS=0
