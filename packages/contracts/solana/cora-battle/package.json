{
  "name": "cora-battle-tests",
  "private": true,
  "scripts": {
    "test": "anchor test",
    "test:local": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=${ANCHOR_WALLET:-$HOME/.config/solana/id.json} ts-mocha -p ./tsconfig.json -t 60000 \"tests/**/*.test.ts\"",
    "test:anchor": "anchor test",
    "test:devnet:anchor": "./scripts/test-devnet-anchor.sh",
    "test:devnet:magicrouter": "./scripts/test-devnet-magicrouter.sh",
    "test:devnet:all": "npm run test:devnet:anchor && npm run test:devnet:magicrouter",
    "test:all:active": "ENABLE_MAGICBLOCK_LOCAL_STACK_TESTS=1 ENABLE_REALTIME_TIMEOUT_TESTS=1 ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=${ANCHOR_WALLET:-$HOME/.config/solana/id.json} EPHEMERAL_PROVIDER_ENDPOINT=${EPHEMERAL_PROVIDER_ENDPOINT:-http://127.0.0.1:7799} EPHEMERAL_WS_ENDPOINT=${EPHEMERAL_WS_ENDPOINT:-ws://127.0.0.1:7800} npm run test:local",
    "test:all:active:auto-stack": "./scripts/test-full-localstack.sh",
    "test:magicblock:local": "ENABLE_MAGICBLOCK_LOCAL_STACK_TESTS=1 ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=${ANCHOR_WALLET:-$HOME/.config/solana/id.json} EPHEMERAL_PROVIDER_ENDPOINT=${EPHEMERAL_PROVIDER_ENDPOINT:-http://127.0.0.1:7799} EPHEMERAL_WS_ENDPOINT=${EPHEMERAL_WS_ENDPOINT:-ws://127.0.0.1:7800} ts-mocha -p ./tsconfig.json -t 180000 \"tests/3*-magicblock-*.test.ts\"",
    "magicblock:base": "npx mb-test-validator --reset --ledger ./.magicblock-test-ledger --bpf-program Azn65FT27X2VpXHgLCXPCqjgWKEeveVzGqEvZcNp2Lic ./target/deploy/cora_battle.so",
    "magicblock:er": "npx ephemeral-validator --reset --remotes http://127.0.0.1:8899 --remotes ws://127.0.0.1:8900 --listen 127.0.0.1:7799 --lifecycle ephemeral"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.0",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@magicblock-labs/ephemeral-validator": "^0.8.8",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "chai": "^4.3.6",
    "magic-router-sdk": "^1.0.10",
    "mocha": "^10.2.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.0.0"
  }
}
