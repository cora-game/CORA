{
  "compilerOptions": {
    "types": ["node", "mocha", "chai"],
    "lib": ["es2020"],
    "module": "commonjs",
    "target": "es6",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist"
  },
  "include": ["tests/**/*.ts"]
}
